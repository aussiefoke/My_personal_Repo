# ==============================
# 复制这个文件为 .env 并填入真实值
# ==============================

# 数据库 (docker-compose 本地默认值)
DATABASE_URL=postgresql://chargesmart:chargesmart@localhost:5432/chargesmart_dev

# Redis (docker-compose 本地默认值)
REDIS_URL=redis://localhost:6379

# JWT 密钥 (生产环境请换成随机长字符串)
JWT_SECRET=dev-secret-change-in-production
JWT_ADMIN_SECRET=dev-admin-secret-change-in-production

# 阿里云短信 (发送验证码用, 开发阶段可留空)
ALIBABA_SMS_ACCESS_KEY=
ALIBABA_SMS_SECRET=
ALIBABA_SMS_SIGN_NAME=

# 高德地图 API Key
AMAP_API_KEY=

# 服务端口
PORT=3000
